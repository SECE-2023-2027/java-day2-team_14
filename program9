import java.util.Arrays;

public class LeftRotateArray {
    public static void main(String[] args) {
        int[] arr = {20, 30, 40};

        System.out.println("Original Array: " + Arrays.toString(arr));

        // Left rotation
        int first = arr[0];
        arr[0] = arr[1];
        arr[1] = arr[2];
        arr[2] = first;

        System.out.println("Rotated Array: " + Arrays.toString(arr));
    }
}
